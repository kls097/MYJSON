{
  "name": "JSON工具箱",
  "version": "4.0.0",
  "description": "JSON格式化、压缩、验证、查询工具,支持历史记录管理",
  "author": "guguangyi",
  "homepage": "https://github.com/guguangyi/myjson-utools-plugin",
  "main": "index.html",
  "logo": "logo.png",
  "preload": "preload.js",
  "pluginSetting": {
    "single": false,
    "height": 600
  },
  "development": {
    "main": "http://localhost:5173"
  },
  "features": [
    {
      "code": "json_editor",
      "explain": "格式化、验证、压缩、查询JSON",
      "icon": "logo.png",
      "cmds": ["JSON", "json", "JSON编辑器", "JSON��具", "JSON格式化"],
      "mainPush": true
    },
    {
      "code": "json_file",
      "explain": "打开文件并作为JSON处理",
      "icon": "logo.png",
      "cmds": [
        {
          "type": "files",
          "label": "用JSON工具打开",
          "fileType": "file",
          "match": "*",
          "minLength": 1,
          "maxLength": 1
        }
      ]
    },
    {
      "code": "json_format",
      "explain": "格式化选中的JSON文本",
      "icon": "logo.png",
      "mainPush": true,
      "cmds": [
        {
          "type": "regex",
          "label": "JSON",
          "match": "/^\\s*(\\{[\\s\\S]*\\}|\\[[\\s\\S]*\\])\\s*$/",
          "minLength": 2,
          "maxLength": 50000000
        }
      ]
    },
    {
      "code": "json_compare",
      "explain": "比较两个JSON的结构差异",
      "icon": "logo.png",
      "cmds": ["JSON比较", "compare json", "JSON对比", "json diff"]
    },
    {
      "code": "json_merge",
      "explain": "智能合并两个JSON对象，支持多种合并策略",
      "icon": "logo.png",
      "cmds": ["JSON合并", "merge json", "json merge", "智能合并"]
    },
    {
      "code": "json_three_way_merge",
      "explain": "三方合并：基础版本、左侧版本、右侧版本",
      "icon": "logo.png",
      "cmds": ["三方合并", "three way merge", "3方合并"]
    },
    {
      "code": "json_convert",
      "explain": "将JSON转换为各种编程语言的类型定义",
      "icon": "logo.png",
      "cmds": ["JSON转换", "convert json", "JSON转代码", "json to code"]
    },
    {
      "code": "json_table",
      "explain": "以表格形式查看和编辑JSON数组",
      "icon": "logo.png",
      "cmds": ["JSON表格", "json table", "表格视图", "table view"]
    }
  ]
}
